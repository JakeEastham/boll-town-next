      "_type": "block",
      "style": "normal",
      "markDefs": [],
      "children": [
        {
          "_key": "b2s1",
          "_type": "span",
          "text": "During their tenure, the club has seen real progress in professionalism and standards across the board. Their efforts have made a lasting impact on this club, and we are incredibly grateful for everything they have contributed. We wish them both the very best in whatever lies ahead.",
          "marks": []
        }
      ]
    },
    {
      "_key": "b3",
      "_type": "block",
      "style": "h2",
      "markDefs": [],
      "children": [
        {
          "_key": "b3s1",
          "_type": "span",
          "text": "A remarkable chapter",
          "marks": []
        }
      ]
    },
