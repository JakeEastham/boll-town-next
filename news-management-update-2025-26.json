          "_key": "b1s4",
          "_type": "span",
          "text": "Stuart Gatward",
          "marks": ["strong"]
        },
        {
          "_key": "b1s5",
          "_type": "span",
          "text": " for their outstanding dedication and commitment as our management team.",
          "marks": []
