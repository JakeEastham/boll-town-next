Options -Indexes
DirectoryIndex index.html

# ─── Compression ────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json application/xml text/plain image/svg+xml
</IfModule>

# ─── Cache Headers ───────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Next.js hashed static assets — safe to cache forever
  <FilesMatch "^\._next\/static\/">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Fonts
  <FilesMatch "\.(woff2?|ttf|otf|eot)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|avif|svg|ico)$">
    ExpiresDefault "access plus 1 month"
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # JS & CSS (non-hashed, e.g. SW or public/)
  <FilesMatch "\.(js|css)$">
    ExpiresDefault "access plus 1 week"
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # HTML — always revalidate
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
  # Hashed _next/static chunks — immutable
  <FilesMatch "^_next\/static\/">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

RewriteEngine On
RewriteBase /

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.bollingtontownfc\.co\.uk$ [NC]
RewriteRule ^(.*)$ https://bollingtontownfc.co.uk/$1 [L,R=301]

# Redirect old /home route
RewriteRule ^home/?$ / [L,R=301]

# SPA fallback for Sanity Studio
RewriteRule ^studio/.+ /studio/index.html [L]

# Custom 404
ErrorDocument 404 /404.html
